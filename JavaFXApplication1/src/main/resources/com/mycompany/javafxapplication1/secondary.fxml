<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TitledPane?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.javafxapplication1.SecondaryController">
    <children>
        <HBox spacing="10"> 
            <Label fx:id="usernameLabel" text="Welcome user"/> 
            <Label fx:id="roleLabel" text="Role: "/> 
        </HBox>
        <Label text="Users List" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Welcome" GridPane.halignment="CENTER" />
            <TextField fx:id="userTextField" GridPane.columnIndex="1" />
            <Label text="Custom data" GridPane.rowIndex="1" />
            <TextField fx:id="customTextField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
         </children>
      </GridPane>
      <HBox spacing="10"> 
          <Button fx:id="uploadButton" text="Upload File" onAction="#handleUpload"/> 
          <Button fx:id="viewButton" text="View File" onAction="#handleView"/>
          <Button fx:id="downloadButton" text="Update File" onAction="#handleUpdate"/> 
          <Button fx:id="deleteButton" text="Delete File" onAction="#handleDelete"/> 
          <Button text="Share" onAction="#handleShare"/>
      </HBox>
      
      <TableView fx:id="fileTable"> 
          <columns> 
              <TableColumn fx:id="fileNameColumn" text="Filename"/> 
              <TableColumn fx:id="ownerColumn" text="Owner"/> 
          </columns> 
      </TableView>
      <TableView fx:id="dataTableView" prefHeight="200.0" prefWidth="200.0" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
              <Button fx:id="secondaryButton" onAction="#switchToPrimary" text="Logout" GridPane.columnIndex="1" />
            <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#RefreshBtnHandler" text="Refresh" />
         </children>
      </GridPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
        <!-- Terminal Section -->
    <TitledPane text="Terminal" expanded="false">
    <content>
        <VBox spacing="5">
            <TextArea fx:id="terminalOutput" editable="false" prefHeight="150" prefWidth="580" 
                      style="-fx-font-family: monospace; -fx-background-color: black; -fx-text-fill: green;"/>
            <HBox spacing="5">
                <Label text="terminal>" style="-fx-font-family: monospace;"/>
                <TextField fx:id="terminalInput" HBox.hgrow="ALWAYS" 
                           onAction="#handleTerminalCommand" style="-fx-font-family: monospace;"/>
                <Button text="Run" onAction="#handleTerminalCommand"/>
            </HBox>
        </VBox>
    </content>
    </TitledPane>
</VBox>
