<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>   

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.javafxapplication1.AdminController">
   <children>
      <Label text="Admin Dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label text="All Users" />
      <TableView fx:id="userTable" prefHeight="200.0" prefWidth="400.0">
         <columns>
            <TableColumn fx:id="userCol" text="Username" prefWidth="200.0" />
            <TableColumn fx:id="roleCol" text="Role" prefWidth="200.0" />
         </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <TextField fx:id="promoteUserField" promptText="Enter username to promote" />
         <Button text="Promote to Admin" onAction="#handlePromote" />
      </HBox>
      
      <Button text="Delete Selected User" onAction="#handleDeleteUser" />
      
      <Button text="Logout" onAction="#handleLogout" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
